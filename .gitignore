# Secrets
.env
.env.*
!.env.example
*.pem
*.key
secrets/
kaggle.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Environnements virtuels
.venv/
venv/
env/

# Tests & couverture
.pytest_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Données (regénérables depuis les sources)
data/raw/
data/processed/
data/interim/
!tests/fixtures/**

# Médias uploadés (stockage local dev uniquement — pas dans Git)
# En production : object storage dédié (S3, MinIO, etc.), comme pour ai-photos.
media/ai-photos/*
!media/ai-photos/.gitkeep
media/posts/*
!media/posts/.gitkeep

# Logs
logs/
*.log

# Dumps BDD locaux
*.sqlite
*.sqlite3
*.db
backups/*.dump
backups/*.sql
!backups/.gitkeep

# Front-end
front-end/node_modules/
front-end/dist/
front-end/.env
front-end/.env.*
!front-end/.env.example

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
