# ============================================================
# HealthAI Coach — environment variables
# Copy this file to `.env` and fill in real values.
# ============================================================

# PostgreSQL (Supabase ou Docker local)
DATABASE_URL=postgresql+psycopg2://healthai:healthai@localhost:5432/healthai

LOG_LEVEL=INFO

# OpenAI — coach IA (/coach/*). Laisser vide si OPENAI_MOCK=true
OPENAI_API_KEY=YOUR-API-KEY
OPENAI_MOCK=false

# JWT Auth (MSPR3)
SECRET_KEY=une-chaine-aleatoire-longue-et-secrete-changez-moi
ACCESS_TOKEN_EXPIRE_DAYS=7

# CORS (front local ou Docker nginx :8080)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://localhost:8000

# ETL (optionnel)
KAGGLE_USERNAME=
KAGGLE_KEY=

# Front (build Vite)
# VITE_API_BASE_URL=http://localhost:8000
