# ============================================================
# HealthAI Coach — environment variables
# Copy this file to `.env` and fill in real values.
# `.env` MUST be in .gitignore (never commit credentials).
# ============================================================

# Supabase Postgres connection string
# Get from: Supabase → Project Settings → Database → Connection string (URI)
# Format:   postgresql+psycopg2://postgres.<project-ref>:<password>@<host>:5432/postgres
DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<password>@aws-0-eu-west-3.pooler.supabase.com:5432/postgres

# Logging level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
